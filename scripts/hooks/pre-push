#!/bin/sh
# Pre-Push-Hook: aktualisiert _data/recent_commits.yml vor jedem Push.
# Einrichtung: sh scripts/install-hooks.sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd)

main() {
    sh "$REPO_ROOT/scripts/generate-recent-commits.sh"
    commit_if_changed
}

commit_if_changed() {
    status=$(git -C "$REPO_ROOT" status --porcelain -- _data/recent_commits.yml)
    [ -n "$status" ] || return 0
    git -C "$REPO_ROOT" add -- _data/recent_commits.yml
    git -C "$REPO_ROOT" \
        -c user.name="Claude Sonnet" \
        -c user.email="agent-sonnet@example.invalid" \
        commit -m "chore: recent_commits.yml aktualisieren (J01-126)"
}

main
